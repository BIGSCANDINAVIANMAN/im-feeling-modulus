resource_name = "dumbert"
script/source = "extends \"res://scenes/characters/dumbert.gd\"

func _physics_process(delta: float) -> void:
	if not get_tree().paused:
		if Input.is_action_just_released(\"space\") and is_on_floor():
			apply_impulse(Vector2(0, -1).rotated(rotation) * 2000 * charge_time)
		
		if Input.is_action_pressed(\"space\") and is_on_floor():
			if charge_time < 1:
				charge_time += delta * 1
			if charge_time > 1:
				charge_time = 1
		else:
			charge_time = 0.5
		
		var x = Input.get_axis(\"left\", \"right\")
		
		if is_on_floor():
			apply_torque(-rotation * 250000) # remains balanced
			apply_torque(x * 150000) # lean
		
		if rotation > 0.6:
			rotation = 0.6
			apply_impulse(Vector2(-50, 0))
		if rotation < -0.6:
			rotation = -0.6
			apply_impulse(Vector2(50, 0))
		
		collectItems()
	
func is_on_floor():
	#print($Area2D.get_overlapping_bodies())
	for body in $Area2D.get_overlapping_bodies():
		if body.is_in_group(\"FLOOR\"):
			return true
	return false
"

