[sub_resource type="GDScript" id="GDScript_o5qli"]
resource_name = "camera"
script/source = "
extends Camera2D

var active = false

func _ready() -> void:
	await get_tree().create_timer(4).timeout
	active = true

func _process(_delta: float) -> void:
	if active:
		var player = get_parent().player
		if player:
			global_position = player.global_position
"

