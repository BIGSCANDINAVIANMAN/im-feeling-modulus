[sub_resource type="GDScript" id="GDScript_o5qli"]
resource_name = "camera"
script/source = "
extends Camera2D

var active = false
var zoomed = true
@export var minZoom = 0.3
@export var maxZoom = 0.6

func _ready() -> void:
	await get_tree().create_timer(4).timeout
	active = true

func _process(_delta: float) -> void:
	if active:
		var player = get_parent().player
		if player:
			global_position = player.global_position

		if zoomed:
			if zoom.x < maxZoom or zoom.y < maxZoom:
				zoom.x += _delta * 0.2
				zoom.y += _delta * 0.2
			if zoom.x > maxZoom:
				zoom.x = maxZoom
			if zoom.y > maxZoom:
				zoom.y = maxZoom
		else:
			if zoom.x > minZoom or zoom.y > minZoom:
				zoom.x -= _delta * 0.2
				zoom.y -= _delta * 0.2
			if zoom.x < minZoom:
				zoom.x = minZoom
			if zoom.y < minZoom:
				zoom.y = minZoom
"

